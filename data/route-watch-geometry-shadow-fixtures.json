{
  "version": "V294",
  "description": "Audit-only Route Watch geometry shadow scoring fixtures. Coordinates are synthetic Liberty County-style LineStrings and are not production incident data.",
  "defaultOptions": {
    "midpointThresholdMiles": 0.8,
    "overlapToleranceMeters": 60,
    "overlapThreshold": 0.25,
    "confidenceThreshold": 0.55
  },
  "fixtures": [
    {
      "id": "midpoint-true-positive",
      "caseType": "midpoint_true_positive",
      "corridor": "US 90",
      "description": "The retained event midpoint lands on a watched-route vertex and the line follows the route.",
      "routeName": "US 90",
      "expectedMidpointRelevant": true,
      "expectedGeometryRelevant": true,
      "expectedConfidenceBand": "high",
      "expectedDisagreementReason": "none",
      "routeGeometry": { "type": "LineString", "coordinates": [[-95.000, 30.000], [-94.980, 30.000], [-94.960, 30.000]] },
      "eventGeometry": { "type": "LineString", "coordinates": [[-94.982, 30.000], [-94.980, 30.000], [-94.978, 30.000]] }
    },
    {
      "id": "midpoint-false-positive",
      "caseType": "midpoint_false_positive",
      "corridor": "US 90",
      "description": "A nearby line has a midpoint inside the vertex-distance threshold but does not overlap the route corridor.",
      "routeName": "nearby county road",
      "expectedMidpointRelevant": true,
      "expectedGeometryRelevant": false,
      "expectedConfidenceBand": "not_relevant",
      "expectedDisagreementReason": "midpoint_false_positive_candidate",
      "routeGeometry": { "type": "LineString", "coordinates": [[-95.000, 30.000], [-94.980, 30.000], [-94.960, 30.000]] },
      "eventGeometry": { "type": "LineString", "coordinates": [[-94.982, 30.004], [-94.980, 30.004], [-94.978, 30.004]] }
    },
    {
      "id": "midpoint-false-negative",
      "caseType": "midpoint_false_negative",
      "corridor": "FM 1960",
      "description": "A sparse route has endpoints only; the event overlaps the route middle but its midpoint is far from route vertices.",
      "routeName": "FM 1960",
      "expectedMidpointRelevant": false,
      "expectedGeometryRelevant": true,
      "expectedConfidenceBand": "high",
      "expectedDisagreementReason": "midpoint_false_negative_candidate",
      "routeGeometry": { "type": "LineString", "coordinates": [[-95.000, 30.000], [-94.960, 30.000]] },
      "eventGeometry": { "type": "LineString", "coordinates": [[-94.982, 30.000], [-94.980, 30.000], [-94.978, 30.000]] }
    },
    {
      "id": "geometry-overlap-true-positive",
      "caseType": "geometry_overlap_true_positive",
      "corridor": "FM 1409",
      "description": "The retained event geometry tracks the watched route for a sustained distance.",
      "routeName": "FM 1409",
      "expectedMidpointRelevant": true,
      "expectedGeometryRelevant": true,
      "expectedConfidenceBand": "high",
      "expectedDisagreementReason": "none",
      "routeGeometry": { "type": "LineString", "coordinates": [[-95.010, 30.010], [-94.990, 30.010], [-94.970, 30.010], [-94.950, 30.010]] },
      "eventGeometry": { "type": "LineString", "coordinates": [[-94.992, 30.010], [-94.990, 30.010], [-94.970, 30.010], [-94.968, 30.010]] }
    },
    {
      "id": "geometry-overlap-true-negative",
      "caseType": "geometry_overlap_true_negative",
      "corridor": "FM 1011",
      "description": "A distant event is neither midpoint-relevant nor geometry-overlap relevant.",
      "routeName": "distant county road",
      "expectedMidpointRelevant": false,
      "expectedGeometryRelevant": false,
      "expectedConfidenceBand": "not_relevant",
      "expectedDisagreementReason": "none",
      "routeGeometry": { "type": "LineString", "coordinates": [[-95.020, 30.020], [-95.000, 30.020], [-94.980, 30.020]] },
      "eventGeometry": { "type": "LineString", "coordinates": [[-95.010, 30.040], [-95.000, 30.040], [-94.990, 30.040]] }
    },
    {
      "id": "sparse-route-geometry-miss",
      "caseType": "sparse_route_geometry_miss",
      "corridor": "FM 1008",
      "description": "The route polyline is too sparse to represent a curved/local alignment, so no-overlap is treated as ambiguous rather than suppressive.",
      "routeName": "FM 1008",
      "routeGeometryQuality": "sparse",
      "expectedMidpointRelevant": false,
      "expectedGeometryRelevant": false,
      "expectedConfidenceBand": "ambiguous",
      "expectedDisagreementReason": "sparse_route_geometry_miss",
      "routeGeometry": { "type": "LineString", "coordinates": [[-95.000, 30.000], [-94.960, 30.000]] },
      "eventGeometry": { "type": "LineString", "coordinates": [[-94.982, 30.018], [-94.980, 30.020], [-94.978, 30.018]] }
    },
    {
      "id": "nearby-parallel-road-non-overlap",
      "caseType": "nearby_parallel_road_non_overlap",
      "corridor": "US 90",
      "description": "A parallel road is close enough for current midpoint relevance but outside the geometry-overlap corridor tolerance.",
      "routeName": "parallel frontage road",
      "expectedMidpointRelevant": true,
      "expectedGeometryRelevant": false,
      "expectedConfidenceBand": "not_relevant",
      "expectedDisagreementReason": "nearby_parallel_non_overlap",
      "routeGeometry": { "type": "LineString", "coordinates": [[-95.000, 30.000], [-94.980, 30.000], [-94.960, 30.000]] },
      "eventGeometry": { "type": "LineString", "coordinates": [[-94.990, 30.002], [-94.980, 30.002], [-94.970, 30.002]] }
    },
    {
      "id": "intersection-adjacent-ambiguity",
      "caseType": "intersection_adjacent_ambiguity",
      "corridor": "FM 1409",
      "description": "A cross-street touches the route at an intersection but does not follow the route alignment.",
      "routeName": "cross street at FM 1409",
      "expectedMidpointRelevant": true,
      "expectedGeometryRelevant": false,
      "expectedConfidenceBand": "ambiguous",
      "expectedDisagreementReason": "intersection_adjacent_ambiguity",
      "routeGeometry": { "type": "LineString", "coordinates": [[-95.000, 30.000], [-94.980, 30.000], [-94.960, 30.000]] },
      "eventGeometry": { "type": "LineString", "coordinates": [[-94.980, 29.997], [-94.980, 30.000], [-94.980, 30.003]] }
    },
    {
      "id": "tx-146-shared-alignment-case",
      "caseType": "tx_146_shared_alignment_case",
      "corridor": "TX 146",
      "description": "A TX 146 retained geometry sample is supported by overlap but flagged for shared-alignment review before production promotion.",
      "routeName": "TX 146 shared alignment",
      "sharedAlignment": true,
      "expectedMidpointRelevant": true,
      "expectedGeometryRelevant": true,
      "expectedConfidenceBand": "ambiguous",
      "expectedDisagreementReason": "shared_alignment_review",
      "routeGeometry": { "type": "LineString", "coordinates": [[-94.820, 30.060], [-94.800, 30.060], [-94.780, 30.060]] },
      "eventGeometry": { "type": "LineString", "coordinates": [[-94.812, 30.060], [-94.800, 30.060], [-94.788, 30.060]] }
    },
    {
      "id": "tx-321-shared-alignment-case",
      "caseType": "tx_321_shared_alignment_case",
      "corridor": "TX 321",
      "description": "A short TX 321 shared alignment has weak overlap and should remain ambiguous in shadow scoring.",
      "routeName": "TX 321 shared alignment",
      "sharedAlignment": true,
      "expectedMidpointRelevant": true,
      "expectedGeometryRelevant": false,
      "expectedConfidenceBand": "ambiguous",
      "expectedDisagreementReason": "shared_alignment_review",
      "routeGeometry": { "type": "LineString", "coordinates": [[-94.900, 30.050], [-94.880, 30.050], [-94.860, 30.050]] },
      "eventGeometry": { "type": "LineString", "coordinates": [[-94.881, 30.050], [-94.880, 30.050], [-94.878, 30.055], [-94.876, 30.060]] }
    }
  ]
}
